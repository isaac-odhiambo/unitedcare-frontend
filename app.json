{
  "expo": {
    "name": "UNITED CARE",
    "slug": "united-care",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "united-care",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0E5E6F"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.unitedcare"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 320,
          "resizeMode": "contain",
          "backgroundColor": "#0E5E6F",
          "dark": {
            "backgroundColor": "#0E5E6F"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow UNITED CARE to access your photos for KYC upload.",
          "cameraPermission": "Allow UNITED CARE to use your camera to capture KYC documents."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
